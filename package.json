{
  "name": "utbk-preparation",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "bun run --cwd apps/backend dev",
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "check:backend": "bun run --cwd apps/backend typecheck",
    "check:frontend": "bun run --cwd apps/frontend typecheck",
    "test:backend": "bun run --cwd apps/backend test",
    "check": "bun run check:backend && bun run check:frontend"
  },
  "packageManager": "bun@1.2.20"
}
